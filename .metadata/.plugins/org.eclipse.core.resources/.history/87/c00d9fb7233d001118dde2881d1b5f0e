// Microcontroller: STM32G071R

// Base address for peripherals
#define PERIPH_BASE		(0x40000000UL)

// Offset for IOPORT peripherals
#define IOPORT_OFFSET	(0x50000000UL)

// Base address for IOPORT peripherals
#define IOPORT_BASE		(PERIPH_BASE + IOPORT_OFFSET)

// GPIOA offset
#define GPIOA_OFFSET	(0x0000UL)

// GPIOA base address
#define GPIOA_BASE		(IOPORT_BASE + GPIOA_OFFSET)

// Offset for AHB bus
#define AHB_OFFSET		(0x10000)

// RCC offset
#define RCC_OFFSET		(0x1000)
